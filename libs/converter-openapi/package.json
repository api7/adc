{
  "name": "@api7/adc-converter-openapi",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/main.js",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/lodash-es": "catalog:",
    "vitest": "catalog:",
    "js-yaml": "catalog:",
    "listr2": "catalog:"
  },
  "dependencies": {
    "@api7/adc-sdk": "workspace:*",
    "@scalar/openapi-parser": "0.28.8",
    "@scalar/openapi-types": "^0.9.1",
    "slugify": "^1.6.6",
    "lodash-es": "catalog:",
    "rxjs": "catalog:",
    "zod": "catalog:",
    "tslib": "catalog:"
  },
  "nx": {
    "name": "converter-openapi",
    "projectType": "library",
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "options": {
          "configFile": "libs/converter-openapi/vitest.config.ts"
        }
      },
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "main": "libs/converter-openapi/src/index.ts",
          "outputPath": "libs/converter-openapi/dist",
          "outputFileName": "main.js",
          "tsConfig": "libs/converter-openapi/tsconfig.lib.json",
          "platform": "node",
          "format": [
            "esm"
          ],
          "declarationRootDir": "libs/converter-openapi/src"
        },
        "configurations": {
          "development": {
            "minify": false
          },
          "production": {
            "minify": true
          }
        }
      }
    }
  }
}
