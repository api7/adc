{
  "name": "@api7/adc-backend-api7",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/main.js",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@api7/adc-differ": "workspace:*",
    "@types/lodash": "catalog:",
    "@types/semver": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@api7/adc-sdk": "workspace:*",
    "@types/json-schema": "^7.0.15",
    "axios": "catalog:",
    "rxjs": "catalog:",
    "lodash": "catalog:",
    "tslib": "catalog:",
    "semver": "catalog:",
    "immer": "catalog:"
  },
  "nx": {
    "name": "backend-api7",
    "projectType": "library",
    "targets": {
      "lint": {
        "executor": "@nx/eslint:lint",
        "outputs": [
          "{options.outputFile}"
        ]
      },
      "test": {
        "executor": "@nx/vitest:test",
        "options": {
          "configFile": "libs/backend-api7/vitest.config.ts"
        }
      },
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "main": "libs/backend-api7/src/index.ts",
          "outputPath": "libs/backend-api7/dist",
          "outputFileName": "main.js",
          "tsConfig": "libs/backend-api7/tsconfig.lib.json",
          "platform": "node",
          "format": [
            "esm"
          ],
          "declarationRootDir": "libs/backend-api7/src"
        },
        "configurations": {
          "development": {
            "minify": false
          },
          "production": {
            "minify": true
          }
        }
      }
    }
  }
}
