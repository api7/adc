{
  "name": "@api7/adc-differ",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/main.js",
  "main": "./dist/main.js",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@types/lodash-es": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@api7/adc-sdk": "workspace:*",
    "lodash-es": "catalog:",
    "datum-diff": "catalog:"
  },
  "nx": {
    "name": "differ",
    "targets": {
      "test": {
        "executor": "@nx/vitest:test",
        "options": {
          "configFile": "libs/differ/vitest.config.ts"
        }
      },
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "main": "libs/differ/src/index.ts",
          "outputPath": "libs/differ/dist",
          "outputFileName": "main.js",
          "tsConfig": "libs/differ/tsconfig.lib.json",
          "platform": "node",
          "format": [
            "esm"
          ],
          "declarationRootDir": "libs/differ/src"
        },
        "configurations": {
          "development": {
            "minify": false
          },
          "production": {
            "minify": true
          }
        }
      }
    }
  }
}
