{
  "name": "@api7/adc",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "catalog:",
    "@types/pluralize": "^0.0.33",
    "@types/qs": "^6.9.15",
    "@types/semver": "catalog:",
    "@types/signale": "^1.4.7",
    "@types/supertest": "^7.2.0",
    "@types/source-map-support": "^0.5.10",
    "semver": "catalog:",
    "supertest": "^7.1.4",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@api7/adc-backend-api7": "workspace:*",
    "@api7/adc-backend-apisix": "workspace:*",
    "@api7/adc-backend-apisix-standalone": "workspace:*",
    "@api7/adc-converter-openapi": "workspace:*",
    "@api7/adc-differ": "workspace:*",
    "@api7/adc-sdk": "workspace:*",
    "agentkeepalive": "^4.6.0",
    "axios": "catalog:",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "glob": "^13.0.0",
    "js-yaml": "catalog:",
    "listr2": "catalog:",
    "lodash-es": "catalog:",
    "parse-duration": "^2.1.5",
    "pluralize": "^8.0.0",
    "qs": "^6.14.1",
    "rxjs": "catalog:",
    "signale": "^1.4.0",
    "source-map-support": "catalog:",
    "winston": "^3.17.0",
    "zod": "catalog:"
  },
  "nx": {
    "name": "cli",
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/cli/src",
    "projectType": "application",
    "tags": [],
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "main": "apps/cli/src/main.ts",
          "outputPath": "dist/apps/cli",
          "outputFileName": "main.js",
          "tsConfig": "apps/cli/tsconfig.app.json",
          "platform": "node",
          "format": [
            "cjs"
          ],
          "declarationRootDir": "apps/cli/src",
          "bundle": true,
          "thirdParty": true,
          "sourcemap": "linked"
        },
        "configurations": {
          "development": {},
          "production": {}
        }
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "outputs": [
          "{options.outputFile}"
        ]
      },
      "test": {
        "executor": "@nx/vitest:test",
        "options": {
          "configFile": "apps/cli/vitest.config.ts"
        }
      },
      "export-schema": {
        "executor": "nx:run-commands",
        "options": {
          "command": "tsx apps/cli/src/linter/exporter.ts"
        }
      }
    }
  }
}
